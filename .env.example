# OpenRouter API key for the live chatbot slide (the offline-first deck).
# Use a CAPPED, DISPOSABLE key (set a low spend limit on openrouter.ai) and
# delete it after the defense. This value is baked into the built JS, so anyone
# who opens the deployed deck can read it.
VITE_OPENROUTER_API_KEY=

# Companion site only. Server-side, set in the Vercel project env (NOT prefixed
# with VITE_, so it is never bundled into the browser). Used by api/chat.ts.
OPENROUTER_API_KEY=
